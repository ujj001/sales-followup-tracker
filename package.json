{
  "name": "followup-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "db:check": "tsx scripts/db-check.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "notify:daily": "tsx scripts/send-daily-followups.ts",
    "notify:daily:dry-run": "tsx scripts/send-daily-followups.ts --dry-run"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "next": "^15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "resend": "^6.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
