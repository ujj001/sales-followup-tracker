# Supabase Postgres connection strings.
# Get these from: Supabase Dashboard → Project → Settings → Database → "Connection string".
#
# DATABASE_URL  = the "Connection pooling" / Transaction pooler string (port 6543).
#                 Append ?pgbouncer=true if it isn't already there.
# DIRECT_URL    = the direct connection string (port 5432). Used only for migrations.
#
# Replace [YOUR-PASSWORD] and the host with your project's values. Do NOT commit the real .env.

DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Email notifications — provider: "agentmail" or "resend"
EMAIL_PROVIDER="agentmail"

# AgentMail (sends from a provisioned inbox; no domain verification needed)
AGENTMAIL_API_KEY="am_xxxxxxxxxxxxxxxxxxxx"
AGENTMAIL_INBOX_ID="your-inbox@agentmail.to"

# Resend (alternative; requires a verified domain to email anyone but yourself)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
NOTIFY_FROM_EMAIL="Follow-up Manager <onboarding@resend.dev>"
